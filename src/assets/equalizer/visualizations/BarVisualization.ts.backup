/* eslint-disable @typescript-eslint/no-unused-vars */
// @ts-nocheck
/**
 * BarVisualization - Classic equalizer bars (line and block styles)
 */

import {
  IVisualization,
  VisualizationMetadata,
  VisualizationConfig,
  ValidationResult,
  LayoutHints,
  RenderContext,
} from './IVisualization';
import { ILayout } from '../layouts/ILayout';

export interface BarVisualizationConfig extends VisualizationConfig {
  style: 'line' | 'block' | 'vertical';
  layout: 'radial' | 'linear';
  endcapType?: string;
  gradient?: boolean;
  borderWidth?: number;
  borderColor?: string;
  barAlignment?: 'bottom' | 'center' | 'top';
  minHeight?: number;
  cornerRadius?: number;
  smoothing?: number;
  peakHold?: boolean;
  peakHoldTime?: number;
  peakDecay?: number;
}

export class BarVisualization extends IVisualization {
  readonly type = 'bar';
  readonly metadata: VisualizationMetadata = {
    name: 'Bar Equalizer',
    description: 'Classic equalizer bars in radial and linear layouts',
    author: 'HAL Builder',
    version: '1.0.0',
    tags: ['classic', 'bars', 'standard'],
  };

  private previousValues: number[] = [];
  private peakValues: number[] = [];
  private peakTimers: number[] = [];

  render(
    context: RenderContext,
    frequencyData: number[],
    config: VisualizationConfig
  ): void {
    // Validate inputs
    if (!context || !context.ctx || !frequencyData) {
      return;
    }

    const barConfig = config as BarVisualizationConfig;

    // Initialize tracking arrays if needed
    if (this.previousValues.length !== config.barCount) {
      this.previousValues = new Array(config.barCount).fill(0);
      this.peakValues = new Array(config.barCount).fill(0);
      this.peakTimers = new Array(config.barCount).fill(0);
    }

    // Apply smoothing and peak tracking
    this.updateValues(frequencyData, barConfig, context);

    if (context.ctx && 'tagName' in context.ctx) {
      this.renderSVG(context.ctx as any, frequencyData, barConfig, context);
    } else if (context.ctx) {
      this.renderCanvas(
        context.ctx as CanvasRenderingContext2D,
        frequencyData,
        barConfig,
        context
      );
    }
  }

  private updateValues(
    frequencyData: number[],
    config: BarVisualizationConfig,
    context: RenderContext
  ): void {
    const smoothing = config.smoothing || 0.7;

    for (let i = 0; i < config.barCount; i++) {
      const currentValue = frequencyData[i] || 0;

      // Apply smoothing
      this.previousValues[i] =
        this.previousValues[i] +
        (currentValue - this.previousValues[i]) * smoothing;

      // Peak hold logic
      if (config.peakHold) {
        if (this.previousValues[i] > this.peakValues[i]) {
          this.peakValues[i] = this.previousValues[i];
          this.peakTimers[i] = context.time + (config.peakHoldTime || 500);
        } else if (context.time > this.peakTimers[i]) {
          this.peakValues[i] = Math.max(
            0,
            this.peakValues[i] - (config.peakDecay || 0.02)
          );
        }
      }
    }
  }

  private renderSVG(
    svg: SVGElement,
    frequencyData: number[],
    config: BarVisualizationConfig,
    context: RenderContext
  ): void {
    const { centerX, centerY } = context;
    const barCount = Math.min(config.barCount, frequencyData.length);

    // Clear existing bars
    while (svg.firstChild) {
      svg.removeChild(svg.firstChild);
    }

    // Create group for transformations
    const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    g.setAttribute(
      'transform',
      `translate(${config.offsetX || 0}, ${config.offsetY || 0})`
    );

    // Add glow filter if needed
    if (config.glowIntensity > 0) {
      g.style.filter = `drop-shadow(0 0 ${config.glowIntensity * 20}px ${config.glowColor || config.primaryColor})`;
    }

    if (config.layout === 'linear') {
      this.renderLinearSVG(g, barCount, config, context);
    } else {
      this.renderRadialSVG(g, barCount, config, context);
    }

    svg.appendChild(g);
  }

  private renderLinearSVG(
    g: SVGElement,
    barCount: number,
    config: BarVisualizationConfig,
    context: RenderContext
  ): void {
    const { centerX, centerY } = context;
    const totalWidth =
      barCount * (config.barWidth + config.barSpacing) - config.barSpacing;
    const startX = centerX - totalWidth / 2;

    for (let i = 0; i < barCount; i++) {
      const value = this.previousValues[i] || 0;
      const barHeight = Math.max(
        config.minHeight || 2,
        value * config.maxHeight
      );
      const x = startX + i * (config.barWidth + config.barSpacing);

      let y: number;
      switch (config.barAlignment) {
        case 'bottom':
          y = centerY + config.maxHeight / 2 - barHeight;
          break;
        case 'center':
          y = centerY - barHeight / 2;
          break;
        case 'top':
          y = centerY - config.maxHeight / 2;
          break;
        default:
          y = centerY + config.maxHeight / 2 - barHeight;
      }

      const color = this.getColor(i, value, barCount, config);
      const rect = document.createElementNS(
        'http://www.w3.org/2000/svg',
        'rect'
      );

      rect.setAttribute('x', x.toString());
      rect.setAttribute('y', y.toString());
      rect.setAttribute('width', config.barWidth.toString());
      rect.setAttribute('height', barHeight.toString());
      rect.setAttribute('fill', color);

      if (config.cornerRadius && config.cornerRadius > 0) {
        rect.setAttribute('rx', config.cornerRadius.toString());
      }

      g.appendChild(rect);

      // Add peak indicator if enabled
      if (config.peakHold && this.peakValues[i] > 0) {
        const peakHeight = this.peakValues[i] * config.maxHeight;
        const peakY =
          config.barAlignment === 'bottom'
            ? centerY + config.maxHeight / 2 - peakHeight
            : centerY - config.maxHeight / 2 + peakHeight;

        const peakLine = document.createElementNS(
          'http://www.w3.org/2000/svg',
          'line'
        );
        peakLine.setAttribute('x1', x.toString());
        peakLine.setAttribute('y1', peakY.toString());
        peakLine.setAttribute('x2', (x + config.barWidth).toString());
        peakLine.setAttribute('y2', peakY.toString());
        peakLine.setAttribute(
          'stroke',
          config.glowColor || config.primaryColor
        );
        peakLine.setAttribute('stroke-width', '2');

        g.appendChild(peakLine);
      }
    }
  }

  private renderRadialSVG(
    g: SVGElement,
    barCount: number,
    config: BarVisualizationConfig,
    context: RenderContext
  ): void {
    const { centerX, centerY } = context;

    // Determine arc vs full circle
    const startDeg = config.arcMode ? config.startAngle || 0 : 0;
    const endDeg = config.arcMode ? config.endAngle || 360 : 360;
    const totalDegRaw = endDeg - startDeg;

    const baseRadius = config.innerRadius || 140;
    // Convert pixel spacing to degrees along the arc at base radius
    const spacingDegPerPx = 360 / (2 * Math.PI * baseRadius);
    let spacingDeg = (config.barSpacing || 0) * spacingDegPerPx;

    // Gaps count differs for arc vs full circle
    const gaps = config.arcMode ? Math.max(0, barCount - 1) : barCount;

    // Ensure spacing doesn't exceed available arc
    if (gaps > 0) {
      const maxSpacing = Math.max(0, (Math.abs(totalDegRaw) / gaps) * 0.9);
      spacingDeg =
        Math.min(Math.abs(spacingDeg), maxSpacing) * Math.sign(totalDegRaw);
    } else {
      spacingDeg = 0;
    }

    const totalDeg = totalDegRaw - spacingDeg * gaps;
    const divisor = config.arcMode
      ? Math.max(1, barCount - 1)
      : Math.max(1, barCount);
    const stepDeg = totalDeg / divisor;

    for (let i = 0; i < barCount; i++) {
      const value = this.previousValues[i] || 0;
      const barHeight = value * config.maxHeight;

      // Angle for this bar with spacing applied
      const angle = startDeg + i * (stepDeg + spacingDeg);
      const angleRad = (angle * Math.PI) / 180 - Math.PI / 2;

      // Anchor point on the base radius
      const xAnchor = centerX + Math.cos(angleRad) * baseRadius;
      const yAnchor = centerY + Math.sin(angleRad) * baseRadius;

      const color = this.getColor(i, value, barCount, config);

      // Apply pulse scaling
      let pulseScale = 1;
      if (config.pulseMode === 'subtle') pulseScale = 1 + value * 0.1;
      else if (config.pulseMode === 'strong') pulseScale = 1 + value * 0.3;

      // Orientation vector (outward radial), then apply additional rotation
      const totalRotateDeg = config.rotation || 0;
      const dirRad = angleRad + (totalRotateDeg * Math.PI) / 180;
      const dx = Math.cos(dirRad);
      const dy = Math.sin(dirRad);

      if (config.style === 'line') {
        const line = document.createElementNS(
          'http://www.w3.org/2000/svg',
          'line'
        );
        const len = barHeight;
        const sign = config.invert ? -1 : 1;
        const x1 = xAnchor;
        const y1 = yAnchor;
        const x2 = xAnchor + dx * len * sign;
        const y2 = yAnchor + dy * len * sign;

        line.setAttribute('x1', x1.toString());
        line.setAttribute('y1', y1.toString());
        line.setAttribute('x2', x2.toString());
        line.setAttribute('y2', y2.toString());
        line.setAttribute('stroke', color);
        line.setAttribute(
          'stroke-width',
          (config.barWidth * pulseScale).toString()
        );
        line.setAttribute('stroke-linecap', 'round');

        g.appendChild(line);
      } else if (config.style === 'block') {
        const rect = document.createElementNS(
          'http://www.w3.org/2000/svg',
          'rect'
        );
        const blockWidth = config.barWidth * 2 * pulseScale;
        const blockX = xAnchor - blockWidth / 2;
        const blockY = yAnchor;

        rect.setAttribute('x', blockX.toString());
        rect.setAttribute('y', blockY.toString());
        rect.setAttribute('width', blockWidth.toString());
        rect.setAttribute('height', barHeight.toString());
        rect.setAttribute('fill', color);

        // Add rotation if specified (sum of rotations)
        const total = (config.rotation || 0) + (config.radialRotation || 0);
        if (total !== 0) {
          const cx = xAnchor;
          const cy = yAnchor + (config.invert ? -barHeight / 2 : barHeight / 2);
          const rotateTransform = `rotate(${total} ${cx} ${cy})`;
          rect.setAttribute('transform', rotateTransform);
        }

        g.appendChild(rect);
      }
    }
  }

  private renderCanvas(
    ctx: CanvasRenderingContext2D,
    frequencyData: number[],
    config: BarVisualizationConfig,
    context: RenderContext
  ): void {
    const { centerX, centerY } = context;
    const barCount = Math.min(config.barCount, frequencyData.length);

    ctx.save();

    // Apply transformations
    ctx.translate(config.offsetX || 0, config.offsetY || 0);

    // Set up glow effect if needed
    if (config.glowIntensity > 0) {
      ctx.shadowColor = config.glowColor || config.primaryColor;
      ctx.shadowBlur = config.glowIntensity * 20;
    }

    if (config.layout === 'linear') {
      this.renderLinearCanvas(ctx, barCount, config, context);
    } else {
      this.renderRadialCanvas(ctx, barCount, config, context);
    }

    ctx.restore();
  }

  private renderLinearCanvas(
    ctx: CanvasRenderingContext2D,
    barCount: number,
    config: BarVisualizationConfig,
    context: RenderContext
  ): void {
    const { centerX, centerY } = context;
    const totalWidth =
      barCount * (config.barWidth + config.barSpacing) - config.barSpacing;
    const startX = centerX - totalWidth / 2;

    for (let i = 0; i < barCount; i++) {
      const value = this.previousValues[i] || 0;
      const barHeight = Math.max(
        config.minHeight || 2,
        value * config.maxHeight
      );
      const x = startX + i * (config.barWidth + config.barSpacing);

      let y: number;
      switch (config.barAlignment) {
        case 'bottom':
          y = centerY + config.maxHeight / 2 - barHeight;
          break;
        case 'center':
          y = centerY - barHeight / 2;
          break;
        case 'top':
          y = centerY - config.maxHeight / 2;
          break;
        default:
          y = centerY + config.maxHeight / 2 - barHeight;
      }

      const color = this.getColor(i, value, barCount, config);
      ctx.fillStyle = color;

      if (config.cornerRadius && config.cornerRadius > 0) {
        this.fillRoundedRect(
          ctx,
          x,
          y,
          config.barWidth,
          barHeight,
          config.cornerRadius
        );
      } else {
        ctx.fillRect(x, y, config.barWidth, barHeight);
      }

      // Add peak indicator if enabled
      if (config.peakHold && this.peakValues[i] > 0) {
        const peakHeight = this.peakValues[i] * config.maxHeight;
        const peakY =
          config.barAlignment === 'bottom'
            ? centerY + config.maxHeight / 2 - peakHeight
            : centerY - config.maxHeight / 2 + peakHeight;

        ctx.fillStyle = config.glowColor || config.primaryColor;
        ctx.fillRect(x, peakY - 1, config.barWidth, 2);
      }
    }
  }

  private renderRadialCanvas(
    ctx: CanvasRenderingContext2D,
    barCount: number,
    config: BarVisualizationConfig,
    context: RenderContext
  ): void {
    const { centerX, centerY } = context;

    // Determine arc vs full circle
    const startDeg = config.arcMode ? config.startAngle || 0 : 0;
    const endDeg = config.arcMode ? config.endAngle || 360 : 360;
    const totalDegRaw = endDeg - startDeg;

    const baseRadius = config.innerRadius || 140;
    // Convert pixel spacing to degrees along the arc at base radius
    const spacingDegPerPx = 360 / (2 * Math.PI * baseRadius);
    let spacingDeg = (config.barSpacing || 0) * spacingDegPerPx;

    // Ensure spacing doesn't exceed available arc
    if (barCount > 1) {
      const maxSpacing = Math.max(
        0,
        (Math.abs(totalDegRaw) / (barCount - 1)) * 0.9
      );
      spacingDeg =
        Math.min(Math.abs(spacingDeg), maxSpacing) * Math.sign(totalDegRaw);
    } else {
      spacingDeg = 0;
    }

    const totalDeg =
      totalDegRaw - (barCount > 1 ? spacingDeg * (barCount - 1) : 0);
    const stepDeg = barCount > 1 ? totalDeg / (barCount - 1) : 0;

    for (let i = 0; i < barCount; i++) {
      const value = this.previousValues[i] || 0;
      const barHeight = value * config.maxHeight;

      // Angle for this bar with spacing applied
      const angle = startDeg + i * (stepDeg + spacingDeg);
      const angleRad = (angle * Math.PI) / 180 - Math.PI / 2;

      // Anchor point on the base radius
      const xAnchor = centerX + Math.cos(angleRad) * baseRadius;
      const yAnchor = centerY + Math.sin(angleRad) * baseRadius;

      const color = this.getColor(i, value, barCount, config);

      // Apply pulse scaling
      let pulseScale = 1;
      if (config.pulseMode === 'subtle') pulseScale = 1 + value * 0.1;
      else if (config.pulseMode === 'strong') pulseScale = 1 + value * 0.3;

      // Orientation vector (outward radial), then apply additional rotation
      const totalRotateDeg =
        (config.rotation || 0) + (config.radialRotation || 0);
      const dirRad = angleRad + (totalRotateDeg * Math.PI) / 180;
      const dx = Math.cos(dirRad);
      const dy = Math.sin(dirRad);

      if (config.style === 'line') {
        ctx.strokeStyle = color;
        ctx.lineWidth = config.barWidth * pulseScale;
        ctx.lineCap = 'round';

        const len = barHeight;
        const sign = config.invert ? -1 : 1;
        const x1 = xAnchor;
        const y1 = yAnchor;
        const x2 = xAnchor + dx * len * sign;
        const y2 = yAnchor + dy * len * sign;

        ctx.beginPath();
        ctx.moveTo(x1, y1);
        ctx.lineTo(x2, y2);
        ctx.stroke();
      } else if (config.style === 'block') {
        ctx.fillStyle = color;

        const blockWidth = config.barWidth * 2 * pulseScale;
        const blockX = xAnchor - blockWidth / 2;

        ctx.save();
        const total = config.rotation || 0;
        if (total !== 0) {
          const cx = xAnchor;
          const cy = yAnchor + (config.invert ? -barHeight / 2 : barHeight / 2);
          ctx.translate(cx, cy);
          ctx.rotate((total * Math.PI) / 180);
          ctx.translate(-cx, -cy);
        }

        ctx.fillRect(blockX, yAnchor, blockWidth, barHeight);
        ctx.restore();
      }
    }

    ctx.restore();
  }

  getDefaultConfig(): BarVisualizationConfig {
    return {
      barCount: 48,
      barWidth: 8,
      barSpacing: 2,
      maxHeight: 200,
      responseSpeed: 0.8,
      colorMode: 'gradient',
      primaryColor: '#dc2626',
      secondaryColor: '#7f1d1d',
      glowIntensity: 0,
      pulseMode: 'none',
      rotation: 0,
      scale: 1,
      offsetX: 0,
      offsetY: 0,
      innerRadius: 140,
      startAngle: 0,
      endAngle: 360,
      arcMode: false,
      invert: false,
      style: 'vertical',
      layout: 'linear',
      barAlignment: 'bottom',
      minHeight: 2,
      cornerRadius: 0,
      smoothing: 0.7,
      peakHold: true,
      peakHoldTime: 500,
      peakDecay: 0.02,
    };
  }

  validateConfig(config: VisualizationConfig): ValidationResult {
    const errors: string[] = [];
    const warnings: string[] = [];

    if (config.barCount <= 0 || config.barCount > 512) {
      errors.push('barCount must be between 1 and 512');
    }

    if (config.barWidth <= 0 || config.barWidth > 50) {
      errors.push('barWidth must be between 0.1 and 50');
    }

    if (config.maxHeight <= 0 || config.maxHeight > 1000) {
      errors.push('maxHeight must be between 1 and 1000');
    }

    if (config.responseSpeed < 0 || config.responseSpeed > 1) {
      errors.push('responseSpeed must be between 0 and 1');
    }

    const barConfig = config as BarVisualizationConfig;
    if (
      barConfig.style &&
      !['line', 'block', 'vertical'].includes(barConfig.style)
    ) {
      errors.push('style must be "line", "block", or "vertical"');
    }

    if (barConfig.layout && !['radial', 'linear'].includes(barConfig.layout)) {
      errors.push('layout must be "radial" or "linear"');
    }

    if (
      barConfig.smoothing &&
      (barConfig.smoothing < 0 || barConfig.smoothing > 1)
    ) {
      errors.push('smoothing must be between 0 and 1');
    }

    if (config.barCount > 128) {
      warnings.push('High bar count may impact performance');
    }

    const result = {
      valid: errors.length === 0,
    } as { valid: boolean; errors?: string[]; warnings?: string[] };

    if (errors.length > 0) {
      result.errors = errors;
    }
    if (warnings.length > 0) {
      result.warnings = warnings;
    }

    return result;
  }

  getAnimatableProperties(): string[] {
    return [
      'barWidth',
      'maxHeight',
      'rotation',
      'scale',
      'offsetX',
      'offsetY',
      'innerRadius',
      'startAngle',
      'endAngle',
      'glowIntensity',
    ];
  }

  supportsLayout(layout: ILayout): boolean {
    // Bar visualization supports radial and linear layouts
    return ['radial', 'linear'].includes(layout.type);
  }

  getLayoutHints(): LayoutHints {
    return {
      preferredLayouts: ['radial', 'linear'],
      minElements: 4,
      maxElements: 512,
      supportsRotation: true,
      supportsScaling: true,
    };
  }

  private fillRoundedRect(
    ctx: CanvasRenderingContext2D,
    x: number,
    y: number,
    width: number,
    height: number,
    radius: number
  ): void {
    ctx.beginPath();
    ctx.moveTo(x + radius, y);
    ctx.arcTo(x + width, y, x + width, y + height, radius);
    ctx.arcTo(x + width, y + height, x, y + height, radius);
    ctx.arcTo(x, y + height, x, y, radius);
    ctx.arcTo(x, y, x + width, y, radius);
    ctx.closePath();
    ctx.fill();
  }
}
